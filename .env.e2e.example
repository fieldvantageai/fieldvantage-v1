# Copie este arquivo para .env.e2e.local e preencha com credenciais reais.

E2E_BASE_URL=http://localhost:3000

E2E_OWNER_EMAIL=owner@empresa.com
E2E_OWNER_PASSWORD=sua-senha
E2E_OWNER_COMPANY_ID=uuid-da-company

E2E_ADMIN_EMAIL=admin@empresa.com
E2E_ADMIN_PASSWORD=sua-senha
E2E_ADMIN_COMPANY_ID=uuid-da-company

E2E_MEMBER_EMAIL=member@empresa.com
E2E_MEMBER_PASSWORD=sua-senha
E2E_MEMBER_COMPANY_ID=uuid-da-company
